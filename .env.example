# Copie a .env.local y rellene con los datos del proyecto Supabase (Settings → API).

NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co

# Clave pública del cliente (elija UNA). Proyectos nuevos suelen mostrar "Publishable":
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
# Si solo tiene la legacy "anon" (JWT), use en su lugar:
# NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# URL pública del sitio (opcional). Use su dominio cuando lo tenga; hasta entonces suele bastar abrir la app por la URL que ya tenga (localhost, *.vercel.app, túnel ngrok, etc.) y el enlace/QR se generará con esa base.
# NEXT_PUBLIC_APP_URL=https://su-dominio.com

# Clave de servidor (elija UNA). Invitación de usuarios, ficha pública (lectura con service role) y operaciones admin:
SUPABASE_SERVICE_ROLE_KEY=
# Si Supabase le dio "Secret" (sb_secret_…):
# SUPABASE_SECRET_KEY=
